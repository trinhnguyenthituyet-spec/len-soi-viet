# Database (PostgreSQL — Supabase ở production, local Postgres khi dev)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/soi_len_viet_dev?schema=public"

# Cloudinary (upload ảnh) — điền giá trị thật từ dashboard Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# NextAuth (admin login)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin seed user (chỉ dùng để seed tài khoản admin đầu tiên)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Domain thật khi deploy (dùng cho sitemap, robots.txt, OG metadata) — để trống thì dùng localhost
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# Sentry (error tracking) — để trống thì Sentry tự tắt (enabled: false), không gửi gì cả.
# Điền sau khi tạo project thật tại sentry.io. SENTRY_DSN và NEXT_PUBLIC_SENTRY_DSN dùng
# cùng giá trị DSN (server và client) — Sentry cho 1 DSN dùng chung được.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
